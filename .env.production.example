# =============================================================================
# PRODUCTION ENVIRONMENT — Copy to .env.production on the server
# =============================================================================

# LinkedIn Credentials (default — users provide their own via Telegram bot)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# AI Service
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Bot Configuration
HEADLESS=True
BROWSER=chrome

# Delays and Timing
MIN_DELAY=2
MAX_DELAY=5
SCROLL_DELAY=1

# Safety Limits
MAX_LIKES_PER_SESSION=5
MAX_COMMENTS_PER_SESSION=5
MAX_MESSAGES_PER_SESSION=5
RANDOMIZE_ACTIONS=True
USE_HUMAN_DELAYS=True

# ─── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# ─── Stripe Payment ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PRICE_ID=YOUR_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ─── Encryption ──────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY

# ─── Database (overridden by docker-compose environment) ──────────────
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=linkedin_bot
DATABASE_USER=linkedin_bot
DATABASE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── URLs (replace YOUR_DOMAIN with your actual domain) ──────────────
# Example: bot.yourdomain.com
PAYMENT_SERVER_URL=https://YOUR_DOMAIN
WEBAPP_URL=https://YOUR_DOMAIN

# ─── Redis (overridden by docker-compose environment) ─────────────────
REDIS_URL=redis://redis:6379/0
