# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# TELEGRAM BOT
# ============================================================================
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================================================
# STRIPE PAYMENT
# ============================================================================
# Get these from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_1xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Stripe webhook signing secret (for production)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# SECURITY
# ============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_base64_encryption_key_here

# ============================================================================
# ANTHROPIC AI
# ============================================================================
# Your Claude API key for AI features
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# TASK QUEUE & MULTI-USER SUPPORT (REDIS + CELERY)
# ============================================================================
# Redis URL for Celery task queue
# Local development: redis://localhost:6379/0
# AWS ElastiCache: redis://your-elasticache-endpoint:6379/0
REDIS_URL=redis://localhost:6379/0

# Browser pool configuration
BROWSER_POOL_SIZE=5
HEADLESS=true

# Celery worker concurrency (number of parallel tasks per worker)
CELERY_WORKER_CONCURRENCY=5

# Set to 'true' only for local testing (runs tasks synchronously)
CELERY_ALWAYS_EAGER=false

# ============================================================================
# AWS S3 STORAGE (SCREENSHOTS)
# ============================================================================
# AWS credentials for S3 screenshot storage
# Get these from AWS IAM console
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# S3 bucket name for screenshots (auto-creates if doesn't exist)
AWS_S3_BUCKET=linkedin-bot-screenshots

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================
# Bot admin Telegram IDs (comma-separated, for admin commands)
ADMIN_IDS=123456789,987654321

# Database path (default: data/telegram_bot.db)
DATABASE_PATH=data/telegram_bot.db

# Enable debug logging
DEBUG=False

# Max concurrent automation jobs (deprecated - use CELERY_WORKER_CONCURRENCY)
MAX_CONCURRENT_JOBS=5
